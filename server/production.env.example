# ─── P2P Lending Platform — Production Environment ──────────────────────────
# Copy this to .env in your production environment and fill in the secrets.

# 🌐 Server Settings
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-app.vercel.app

# 🗄️ Database
# Use a production MongoDB Atlas cluster string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.abc.mongodb.net/p2p-prod?retryWrites=true&w=majority

# 🔐 Security
# Generate long, random strings for these
JWT_SECRET=your_ultra_secure_random_string_here
JWT_EXPIRES_IN=7d

# 💳 Stripe Payments
# Use LIVE keys for production (sk_live_... and pk_live_...)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ⚓ Stripe Webhooks
# Get this from your Stripe Dashboard > Webhooks > Add Endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# 📧 Mail Settings (Optional/Phase 5)
# EMAIL_SERVICE=SendGrid
# SENDGRID_API_KEY=...
